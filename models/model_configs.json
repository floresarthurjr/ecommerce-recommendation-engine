{
  "champion_model": "Model 5: XGBoost Ranker",
  "kmeans_k": 3,
  "kmeans_silhouette": 0.181,
  "kmeans_features": [
    "Age",
    "Purchase Amount (USD)",
    "Review Rating",
    "Previous Purchases",
    "Gender",
    "Size",
    "Frequency of Purchases",
    "Subscription Status",
    "Discount Applied",
    "engagement_score",
    "spending_tier",
    "customer_maturity"
  ],
  "xgboost_params": {
    "n_estimators": 1000,
    "max_depth": 7,
    "learning_rate": 0.1,
    "subsample": 1.0,
    "min_child_weight": 1
  },
  "xgboost_scale_pos_weight": 24,
  "evaluation_metrics": {
    "primary_tollgate": "NDCG@10",
    "champion_ndcg10": 0.176,
    "champion_recall10": 0.39,
    "champion_precision5": 0.041,
    "baseline_ndcg10": 0.163,
    "improvement_over_baseline": "7.9%"
  },
  "train_test_split": {
    "method": "demographic-stratified random",
    "test_size": 0.2,
    "random_state": 42,
    "stratify_on": "age_group x Gender"
  }
}